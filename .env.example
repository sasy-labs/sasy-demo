# Copy this file to .env and fill in both values.
#
#   cp .env.example .env

# OpenAI API key (required — the agent uses gpt-4.1)
OPENAI_API_KEY=sk-your-key-here

# SASY API key (provided to you by us)
SASY_API_KEY=demo-key-your-key-here

# Optional: bring-your-own Anthropic key for translation. Leave
# commented to use the server's key (subject to a shared rate limit).
# Uncomment + fill in if you hit the server-side limit.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
