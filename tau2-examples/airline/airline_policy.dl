/* Airline Agent Policy — tau2 benchmark

   Enforcement target: LLMAgent (the airline customer-service assistant).
   User messages in the dependency graph are attributed to
   msg.agent = "LLMAgent" with msg.agent_role = $UserRole() per the
   tau2 instrumentation.  Content checks use custom C++ functors
   declared below and implemented in airline_functors.cpp
   (keyword/phrase matchers instead of @llm_check_fn).
*/
#include "../../policies/common_policy.dl"

/* ── Structured Spec ──────────────────────────────────────────────
   C1:  Authorize all airline agent tool calls by default
   C2:  Deny unauthorized actions with an error response
   C3:  Deny booking/modify/cancel writes without prior explicit
        user "yes" confirmation in the dependency chain
   C4:  Deny book_reservation with more than 5 passengers
   C5:  Deny book_reservation with total_baggages > 0 unless the
        user explicitly asked for checked bags
   C6:  Deny update_reservation_flights on a basic-economy reservation
        (spec: basic economy flights cannot be modified)
   C7:  Deny update_reservation_flights (cabin change) when the
        reservation has any flown flight
   C8:  Deny update_reservation_baggages that reduces bag count
   C9:  Deny update_reservation_baggages without a prior
        get_reservation_details result in the dependency chain
   C10: Deny update_reservation_* tools that add insurance
        (insurance=yes) post-booking
   C11: Deny cancel_reservation when the reservation has any flown flight
   C12: Deny cancel_reservation when the user's stated reason is
        a user error (accidental booking, mistake, wrong flight)
        unless cancellation is unconditionally allowed
   C13: Deny cancel_reservation when the stated reason is a trivial
        social event, unless cancellation is unconditionally allowed
   C14: Deny cancel_reservation when no valid covered reason has been
        stated and cancellation is not unconditionally allowed
   C15: Deny send_certificate when verified membership level is "regular"
   C16: Deny send_certificate when membership has not been verified
   C17: Deny send_certificate without a confirmed delayed/cancelled flight
   C18: Deny send_certificate when the user has not explicitly requested
        compensation (no proactive offers)
   ──────────────────────────────────────────────────────────────── */

/* ═══════════════════════════════════════════════════════════════
   CUSTOM C++ FUNCTOR DECLARATIONS (airline_policy_souffle_functors.cpp)
   ═══════════════════════════════════════════════════════════════ */

/* Content classifiers over message.contents (keyword/phrase matchers). */
.functor user_requested_bags(text: symbol): unsigned stateful
.functor user_confirmed_yes(text: symbol): unsigned stateful
.functor user_error_reason(text: symbol): unsigned stateful
.functor trivial_social_reason(text: symbol): unsigned stateful
.functor covered_cancellation_reason(text: symbol): unsigned stateful
.functor user_requested_compensation(text: symbol): unsigned stateful

/* JSON helpers. */
.functor count_passengers(args: symbol): number stateful
.functor extract_first_flight(json: symbol): symbol stateful

/* ═══════════════════════════════════════════════════════════════
   DEFAULT AUTHORIZATION
   ═══════════════════════════════════════════════════════════════ */

/* C1: Authorize all airline agent tool calls by default */
IsAuthorized(idx) :- Actions(idx, _).

/* C2: Deny unauthorized actions with an error response */
DenyUnauthorized(idx) :- Actions(idx, _).

/* ═══════════════════════════════════════════════════════════════
   TOOL-RESULT FIELD DECLARATIONS
   ═══════════════════════════════════════════════════════════════ */

ToolResultFieldName("membership").
ToolResultFieldName("cabin").
ToolResultFieldName("reservation_id").
ToolResultFieldName("insurance").

/* ═══════════════════════════════════════════════════════════════
   HELPER RELATIONS — RESERVATION DATA
   ═══════════════════════════════════════════════════════════════ */

/* First flight number per reservation (for detecting flight changes). */
.decl ReservationFirstFlight(res_id: symbol, flight_num: symbol)
ReservationFirstFlight(res_id, flight_num) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    flight_num = @extract_first_flight(msg.contents), flight_num != "".

/* Detect if the flights are actually being changed (not just cabin). */
.decl FlightsBeingChanged(res_id: symbol)
FlightsBeingChanged(res_id) :-
    Actions(idx, a), IsTool(a, "update_reservation_flights"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    new_flight = @extract_first_flight(args), new_flight != "",
    ReservationFirstFlight(res_id, old_flight),
    new_flight != old_flight.

/* Cabin per reservation, extracted from get_reservation_details. */
.decl ReservationHasCabin(res_id: symbol, cabin: symbol)
ReservationHasCabin(res_id, cabin) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    cabin = @json_get_str(msg.contents, "cabin"), cabin != "".

/* Baggage count per reservation. */
.decl ReservationBagCount(res_id: symbol, bag_count: number)
ReservationBagCount(res_id, bag_count) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    bag_count = @json_get_int(msg.contents, "total_baggages"),
    bag_count >= 0.

/* Reservations with any flown flight (status "landed" or "flying"). */
.decl ReservationHasFlownFlight(res_id: symbol)
ReservationHasFlownFlight(res_id) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    @str_contains(msg.contents, "landed") = 1.
ReservationHasFlownFlight(res_id) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    @str_contains(msg.contents, "flying") = 1.

/* Reservation has insurance according to get_reservation_details. */
.decl ReservationHasInsurance(res_id: symbol)
ReservationHasInsurance(res_id) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    ins = @json_get_str(msg.contents, "insurance"),
    ins = "yes".

/* ═══════════════════════════════════════════════════════════════
   HELPER RELATIONS — FLIGHT STATUS
   ═══════════════════════════════════════════════════════════════ */

/* Confirmed delayed or cancelled flight via get_flight_status. */
.decl ConfirmedDelayedOrCancelledFlight()
ConfirmedDelayedOrCancelledFlight() :-
    CurrentDepends(mid),
    ToolResult(mid, "get_flight_status", _),
    SentMessage(mid, msg),
    @str_contains(msg.contents, "delayed") = 1.
ConfirmedDelayedOrCancelledFlight() :-
    CurrentDepends(mid),
    ToolResult(mid, "get_flight_status", _),
    SentMessage(mid, msg),
    @str_contains(msg.contents, "cancelled") = 1.

/* Confirmed airline-cancelled flight — a subset useful for cancellation. */
.decl AirlineCancelledFlight()
AirlineCancelledFlight() :-
    CurrentDepends(mid),
    ToolResult(mid, "get_flight_status", _),
    SentMessage(mid, msg),
    @str_contains(msg.contents, "cancelled") = 1.

/* ═══════════════════════════════════════════════════════════════
   HELPER RELATIONS — CANCELLATION ELIGIBILITY
   ═══════════════════════════════════════════════════════════════ */

/* Unconditional cancellation eligibility, scoped to a specific reservation:
   - The reservation's cabin is business
   - An airline-cancelled flight exists (global — applies to any cancel)
   - The reservation has insurance AND user stated a covered reason
   - The reservation was booked within the last 24 hours */
.decl CancellationAllowedFor(res_id: symbol)
CancellationAllowedFor(res_id) :-
    ReservationHasCabin(res_id, "business").
CancellationAllowedFor(res_id) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    AirlineCancelledFlight().
CancellationAllowedFor(res_id) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    ins = @json_get_str(msg.contents, "insurance"), ins = "yes",
    ValidCoveredReasonStated().
CancellationAllowedFor(res_id) :-
    CurrentDepends(mid),
    ToolResult(mid, "get_reservation_details", _),
    SentMessage(mid, msg),
    res_id = @json_get_str(msg.contents, "reservation_id"), res_id != "",
    created = @json_get_str(msg.contents, "created_at"), created != "",
    @hours_between(created, "2024-05-15T15:00:00") < 24,
    @hours_between(created, "2024-05-15T15:00:00") >= 0.

/* ═══════════════════════════════════════════════════════════════
   HELPER RELATIONS — MEMBERSHIP
   ═══════════════════════════════════════════════════════════════ */

.decl MembershipVerified()
MembershipVerified() :- ToolResultField("get_user_details", "membership", _).

/* ═══════════════════════════════════════════════════════════════
   HELPER RELATIONS — USER INTENT (custom functor classifiers)
   All predicates below filter on msg.agent = "LLMAgent" AND
   msg.agent_role = $UserRole() so only end-user messages to the
   enforcement-target agent count.
   ═══════════════════════════════════════════════════════════════ */

/* User explicitly requested checked bags. */
.decl UserRequestedBags()
UserRequestedBags() :-
    CurrentDepends(mid),
    SentMessage(mid, msg),
    msg.agent = "LLMAgent",
    msg.agent_role = $UserRole(),
    @user_requested_bags(msg.contents) = 1.

/* User gave affirmative confirmation (yes / confirm / proceed / ok). */
.decl UserConfirmed()
UserConfirmed() :-
    CurrentDepends(mid),
    SentMessage(mid, msg),
    msg.agent = "LLMAgent",
    msg.agent_role = $UserRole(),
    @user_confirmed_yes(msg.contents) = 1.

/* User stated a user-error reason for cancellation. */
.decl UserErrorCancellationReason()
UserErrorCancellationReason() :-
    CurrentDepends(mid),
    SentMessage(mid, msg),
    msg.agent = "LLMAgent",
    msg.agent_role = $UserRole(),
    @user_error_reason(msg.contents) = 1.

/* User stated a trivial-social-event reason for cancellation. */
.decl TrivialSocialCancellationReason()
TrivialSocialCancellationReason() :-
    CurrentDepends(mid),
    SentMessage(mid, msg),
    msg.agent = "LLMAgent",
    msg.agent_role = $UserRole(),
    @trivial_social_reason(msg.contents) = 1.

/* User stated a valid insurance-covered reason. */
.decl ValidCoveredReasonStated()
ValidCoveredReasonStated() :-
    CurrentDepends(mid),
    SentMessage(mid, msg),
    msg.agent = "LLMAgent",
    msg.agent_role = $UserRole(),
    @covered_cancellation_reason(msg.contents) = 1.

/* User explicitly asked for compensation / a certificate. */
.decl UserRequestedCompensation()
UserRequestedCompensation() :-
    CurrentDepends(mid),
    SentMessage(mid, msg),
    msg.agent = "LLMAgent",
    msg.agent_role = $UserRole(),
    @user_requested_compensation(msg.contents) = 1.

/* ═══════════════════════════════════════════════════════════════
   ENFORCEMENT RULES
   ═══════════════════════════════════════════════════════════════ */

/* C3: Write tools require a prior user "yes" in the dependency chain. */
// @deny_message: Write action not explicitly confirmed by the user
// @suggestion: List all action details to the user and wait for an explicit affirmative reply (e.g. "yes") before calling this tool.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "book_reservation"),
    !UserConfirmed().
// @deny_message: Write action not explicitly confirmed by the user
// @suggestion: List all action details to the user and wait for an explicit affirmative reply (e.g. "yes") before calling this tool.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_flights"),
    !UserConfirmed().
// @deny_message: Write action not explicitly confirmed by the user
// @suggestion: List all action details to the user and wait for an explicit affirmative reply (e.g. "yes") before calling this tool.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_baggages"),
    !UserConfirmed().
// @deny_message: Write action not explicitly confirmed by the user
// @suggestion: List all action details to the user and wait for an explicit affirmative reply (e.g. "yes") before calling this tool.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_passengers"),
    !UserConfirmed().
// @deny_message: Write action not explicitly confirmed by the user
// @suggestion: List all action details to the user and wait for an explicit affirmative reply (e.g. "yes") before calling this tool.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "cancel_reservation"),
    !UserConfirmed().

/* C4: At most five passengers on a booking. */
// @deny_message: Reservations may have at most five passengers
// @suggestion: Split the party across multiple reservations or remove passengers so the booking has five or fewer.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "book_reservation"),
    a = $CallTool(_, args),
    @count_passengers(args) > 5.

/* C5: Do not add checked bags the user did not request. */
// @deny_message: User did not request checked bags
// @suggestion: Do not add checked bags unless the user explicitly asks. Set total_baggages and nonfree_baggages to 0.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "book_reservation"),
    a = $CallTool(_, args),
    @json_get_int(args, "total_baggages") > 0,
    !UserRequestedBags().

/* C6: Basic-economy reservations cannot change flights or dates.
       The only allowed update_reservation_flights on basic economy is a
       cabin upgrade (changing cabin to economy or business while keeping
       flights identical). Deny if: cabin stays basic_economy (meaning the
       change is to flights/dates), OR flight numbers actually differ. */
// @deny_message: Basic economy flights cannot be modified
// @suggestion: Basic economy reservations cannot change flights. You may only change the cabin class while keeping the same flights, or cancel and rebook.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_flights"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    ReservationHasCabin(res_id, "basic_economy"),
    new_cabin = @json_get_str(args, "cabin"),
    new_cabin = "basic_economy".
// @deny_message: Basic economy flights cannot be modified
// @suggestion: Basic economy reservations cannot change flights. You may only change the cabin class while keeping the same flights, or cancel and rebook.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_flights"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    ReservationHasCabin(res_id, "basic_economy"),
    FlightsBeingChanged(res_id).

/* C7: Cabin cannot change if any flight in the reservation has flown. */
// @deny_message: Cannot change cabin on a reservation with flown flights
// @suggestion: Cabin changes are not allowed once any flight in the reservation has departed. Transfer to a human agent if needed.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_flights"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    new_cabin = @json_get_str(args, "cabin"), new_cabin != "",
    ReservationHasCabin(res_id, old_cabin),
    new_cabin != old_cabin,
    ReservationHasFlownFlight(res_id).

/* C8: Baggage may be added but not removed. */
// @deny_message: Cannot remove checked bags from a reservation
// @suggestion: Checked bags can only be added, not removed. The new total_baggages must be >= the current count.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_baggages"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    new_count = @json_get_int(args, "total_baggages"),
    ReservationBagCount(res_id, old_count),
    new_count < old_count.

/* C9: Baggage update must be preceded by get_reservation_details. */
// @deny_message: Reservation details not verified before baggage update
// @suggestion: Call get_reservation_details first to check the current baggage count before updating.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_baggages"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    !ReservationBagCount(res_id, _).

/* C10: Insurance cannot be added after the initial booking. */
// @deny_message: Insurance cannot be added after the initial booking
// @suggestion: Travel insurance can only be purchased at booking time. Do not set insurance to "yes" on an update call.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_baggages"),
    a = $CallTool(_, args),
    new_ins = @json_get_str(args, "insurance"),
    new_ins = "yes",
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    !ReservationHasInsurance(res_id).
// @deny_message: Insurance cannot be added after the initial booking
// @suggestion: Travel insurance can only be purchased at booking time. Do not set insurance to "yes" on an update call.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_flights"),
    a = $CallTool(_, args),
    new_ins = @json_get_str(args, "insurance"),
    new_ins = "yes",
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    !ReservationHasInsurance(res_id).
// @deny_message: Insurance cannot be added after the initial booking
// @suggestion: Travel insurance can only be purchased at booking time. Do not set insurance to "yes" on an update call.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "update_reservation_passengers"),
    a = $CallTool(_, args),
    new_ins = @json_get_str(args, "insurance"),
    new_ins = "yes",
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    !ReservationHasInsurance(res_id).

/* C11: Cannot cancel a reservation with any flown flight. */
// @deny_message: Cannot cancel a reservation with flown flights
// @suggestion: A flight in this reservation has already departed or landed. Cancellation is not possible; transfer the user to a human agent.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "cancel_reservation"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    ReservationHasFlownFlight(res_id).

/* C12: User-error cancellation reasons are not covered. */
// @deny_message: User error is not a covered cancellation reason
// @suggestion: Accidental booking, double-booking or picking the wrong flight is not covered by travel insurance. Covered reasons: health, weather, work/family emergencies, or airline cancellation. Transfer to a human agent if the user insists.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "cancel_reservation"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    UserErrorCancellationReason(),
    !CancellationAllowedFor(res_id).

/* C13: Trivial social events are not covered cancellation reasons. */
// @deny_message: Trivial social events are not covered cancellation reasons
// @suggestion: Birthdays, parties, celebrations and concerts are not significant personal circumstances under travel insurance. Covered reasons: health, weather, work/family emergencies.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "cancel_reservation"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    TrivialSocialCancellationReason(),
    !CancellationAllowedFor(res_id).

/* C14: No valid cancellation reason stated and cancellation not otherwise allowed. */
// @deny_message: No valid cancellation reason provided
// @suggestion: Ask the user for the cancellation reason before proceeding. Covered reasons: health issues, weather, work/family emergencies, or airline cancellation of the flight.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "cancel_reservation"),
    a = $CallTool(_, args),
    res_id = @json_get_str(args, "reservation_id"), res_id != "",
    !ValidCoveredReasonStated(),
    !UserErrorCancellationReason(),
    !TrivialSocialCancellationReason(),
    !CancellationAllowedFor(res_id).

/* C15: Regular members are NOT eligible for compensation. */
// @deny_message: Regular members are not eligible for compensation
// @suggestion: Only silver and gold members can receive a travel certificate. This user has a regular membership. Do not offer compensation.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "send_certificate"),
    ToolResultField("get_user_details", "membership", "regular").

/* C16: Membership must be verified before sending a certificate. */
// @deny_message: Membership level not verified
// @suggestion: Call get_user_details to verify the user's membership level before offering compensation. Only silver and gold members are eligible.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "send_certificate"),
    !MembershipVerified().

/* C17: Certificate requires a confirmed delayed or cancelled flight. */
// @deny_message: No confirmed delayed or cancelled flight
// @suggestion: Verify the flight status with get_flight_status before offering compensation. Certificates are only for confirmed delayed ($50/passenger) or cancelled ($100/passenger) flights.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "send_certificate"),
    !ConfirmedDelayedOrCancelledFlight().

/* C18: Do not proactively offer compensation — the user must have asked. */
// @deny_message: Compensation was not requested by the user
// @suggestion: Do not proactively offer compensation. Only send a certificate when the user has explicitly asked for compensation, a refund, or a certificate.
Unauthorized(idx) :-
    Actions(idx, a),
    IsTool(a, "send_certificate"),
    !UserRequestedCompensation().
